+        int16_t  current_ma = (int16_t) (regs[7] << 8 | regs[6]);   // 0x0C-0x0D
+
+        uint8_t soc_regs[4] = {0};
+        ReadRegs(0x2C, soc_regs, 4);
+        uint16_t soc_pct = (uint16_t)(soc_regs[1] << 8 | soc_regs[0]);
+
+        if (voltage_mv < 1500 || voltage_mv > 9500) {
+            valid_ = false;
+            return;
+        }
+
+        if (soc_pct <= 100) {
